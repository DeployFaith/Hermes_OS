#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="~/Nextcloud/Create/repos/hermes-agent/HermesOS"
COMPOSE_FILE="$REPO_DIR/docker-compose.hermes.yml"
ENV_FILE="$REPO_DIR/runtime/live_bridge/compose.env"
PROJECT="hermesos"
SERVICE="hermes-live-bridge"
CONTAINER="hermes-live-bridge"
PROFILE="hermesos"

if command -v docker-compose >/dev/null 2>&1; then
  COMPOSE_CMD=(docker-compose)
elif command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
  COMPOSE_CMD=(docker compose)
else
  echo "ERROR: docker-compose (or docker compose) is required." >&2
  exit 1
fi

if [[ ! -f "$COMPOSE_FILE" ]]; then
  echo "ERROR: compose file not found: $COMPOSE_FILE" >&2
  exit 1
fi

COMPOSE_ARGS=(-p "$PROJECT")
if [[ -f "$ENV_FILE" ]]; then
  COMPOSE_ARGS+=(--env-file "$ENV_FILE")
fi
COMPOSE_ARGS+=(-f "$COMPOSE_FILE")

container_id="$(docker ps -aq --filter "name=^/${CONTAINER}$")"
if [[ -n "$container_id" ]]; then
  if [[ -z "$(docker ps -q --filter "id=$container_id")" ]]; then
    docker start "$CONTAINER" >/dev/null
  fi
else
  "${COMPOSE_CMD[@]}" "${COMPOSE_ARGS[@]}" up -d --no-recreate "$SERVICE" >/dev/null
fi

if [[ $# -eq 0 ]]; then
  if [[ -t 0 && -t 1 ]]; then
    exec docker exec -it "$CONTAINER" hermes -p "$PROFILE"
  else
    exec docker exec "$CONTAINER" hermes -p "$PROFILE"
  fi
else
  exec docker exec "$CONTAINER" hermes -p "$PROFILE" "$@"
fi
