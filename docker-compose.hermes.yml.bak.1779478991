version: '3.8'

services:
  hermes-live-bridge:
    build:
      context: ./runtime/live_bridge
      dockerfile: Dockerfile
    container_name: hermes-live-bridge
    restart: unless-stopped
    user: "${LOCAL_UID:-1000}:${LOCAL_GID:-1000}"
    ports:
      - "${HERMES_BRIDGE_PORT:-8788}:8788"
    environment:
      PORT: 8788
      WS_PATH: /hermesos/ws
      HERMES_HOME: /hermes-home
      HERMES_PROFILE: ${HERMES_PROFILE:-hermesos}
      HERMES_PROVIDER: ${HERMES_PROVIDER:-}
      HERMES_MODEL: ${HERMES_MODEL:-}
      HERMES_BASE_URL: ${HERMES_BASE_URL:-}
      HERMES_TIMEOUT_MS: ${HERMES_TIMEOUT_MS:-120000}
      MAX_PROMPT_CHARS: ${MAX_PROMPT_CHARS:-2000}
      MAX_REPLY_CHARS: ${MAX_REPLY_CHARS:-8000}
      OPENROUTER_API_KEY: ${OPENROUTER_API_KEY:-}
      ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY:-}
      OPENAI_API_KEY: ${OPENAI_API_KEY:-}
      GEMINI_API_KEY: ${GEMINI_API_KEY:-}
      GOOGLE_API_KEY: ${GOOGLE_API_KEY:-}
      DEEPSEEK_API_KEY: ${DEEPSEEK_API_KEY:-}
      XAI_API_KEY: ${XAI_API_KEY:-}
    volumes:
      - ./runtime/live_bridge/hermes-home:/hermes-home
    healthcheck:
      test: ["CMD", "bash", "-lc", "pgrep -f 'node server.js' >/dev/null"]
      interval: 20s
      timeout: 5s
      retries: 5
      start_period: 20s
